# Cerebras API Key (required - get free at https://cloud.cerebras.ai)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_MODEL_FAST=gpt-oss-120b

# Privacy Encryption (required - Fernet key for encrypting sensitive data at rest)
FERNET_KEY=your_fernet_key_here

# JWT Secret for tenant authentication (required)
JWT_SECRET=your_jwt_secret_here

# Fund Dashboard Password
FUND_PASSWORD=your_dashboard_password

# Blockchain Configuration (optional - for ledger logging)
WEB3_RPC_URL=https://sepolia.base.org
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# Coinbase AgentKit Token (optional)
COINBASE_AGENT_KIT_TOKEN=your_agentkit_token_here

# Email Digest (Gmail SMTP)
DIGEST_EMAIL=your_email@gmail.com
DIGEST_PASSWORD=your_app_password

# Neon PostgreSQL
NEON_URL=your_neon_postgresql_url_here

# Logging
LOG_LEVEL=WARNING